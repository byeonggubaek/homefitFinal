 "license": "ISC",
 "description": "npm 이용하여 frontend, backend, shared repo들을 만든다.",
 "private": true,
 "type": "module",
 "workspaces": [
  "packages/*"
 ],
 "scripts": {
  "dev": "npm run dev -w frontend & npm run dev -w backend",
  "type-check": "npm run type-check -w frontend && npm run type-check -w backend && npm run type-check -w shared",
  "build": "npm run build -w frontend && npm run build -w backend && npm run build -w shared"
 },
